{
  "name": "sistema-atendimento-cliente",
  "version": "1.0.0",
  "description": "Sistema de atendimento ao cliente multicanal e multiusuário",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client:wait\"",
    "dev:server": "nodemon --exec ts-node src/server.ts",
    "dev:client:wait": "wait-on tcp:3007 && npm run dev:client",
    "dev:client": "cd client && npm run dev",
    "build": "tsc && cd client && npm run build",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "seed": "ts-node src/scripts/seed.ts",
    "create:user": "ts-node src/scripts/createTestUser.ts",
    "check:enilson": "ts-node scripts/checkEnilson.ts",
    "check:database": "ts-node scripts/checkDatabase.ts",
    "check:channels": "ts-node scripts/checkWhatsAppOfficialChannel.ts",
    "perf:phase0": "k6 run scripts/load/phase0-conversations.js",
    "perf:phase0:quick": "k6 run -e BASE_URL=http://localhost:3007 -e VUS=20 -e DURATION=2m scripts/load/phase0-conversations.js",
    "perf:phase1": "k6 run scripts/load/phase1-mixed.js",
    "perf:phase1:quick": "k6 run -e BASE_URL=http://localhost:3007 -e VUS=20 -e DURATION=3m -e WRITE_ENABLED=false scripts/load/phase1-mixed.js",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:setup": "prisma migrate deploy && prisma generate"
  },
  "keywords": [
    "chat",
    "atendimento",
    "evolution-api",
    "whatsapp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@prisma/client": "^5.7.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "prisma": "^5.7.1",
    "socket.io": "^4.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.2.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "wait-on": "^9.0.5"
  }
}
