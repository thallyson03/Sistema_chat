# Copie para .env local. No Coolify, defina as mesmas chaves na UI do serviço.
#
# Coolify (resumo):
# - Tipo: Dockerfile na raiz do repositório
# - Porta do container: 3007 (ou defina PORT e alinhe no painel)
# - Banco: crie um PostgreSQL no Coolify e use a DATABASE_URL gerada
# - Variáveis: todas abaixo + segredos (JWT, WhatsApp, Evolution, etc.)
# - Volume persistente: monte em /app/uploads (mídias / uploads)
# - Build args (opcional): VITE_API_BASE_URL vazio = mesmo domínio da API
# - Domínio público: APP_URL (ou PUBLIC_APP_URL) deve ser URL completa, ex: https://crm.seudominio.com
#   Não defina API_BASE_URL só como "https" — mídia para a Meta falha sem host.

PORT=3007
NODE_ENV=production

# Obrigatório — Postgres (Coolify: use o recurso Database ou URL interna)
DATABASE_URL=postgresql://USER:SENHA@HOST:5432/sistema_atendimento?schema=public

JWT_SECRET=
JWT_EXPIRES_IN=7d

# URL pública do painel (mesma URL que o usuário acessa no navegador)
CORS_ORIGIN=https://app.seudominio.com
APP_URL=https://app.seudominio.com
API_BASE_URL=https://app.seudominio.com
# Opcional: sobrescreve APP_URL só para montar links de mídia (WhatsApp Official)
# PUBLIC_APP_URL=https://app.seudominio.com

# Evolution / WhatsApp (ajuste conforme seu ambiente)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Opcional — só se o front for buildado apontando para outra API
# No Dockerfile/Coolify Build Argument: VITE_API_BASE_URL

# WhatsApp Official (se usar)
WHATSAPP_ENV=dev
WHATSAPP_DEV_TOKEN=
WHATSAPP_DEV_PHONE_NUMBER_ID=
WHATSAPP_DEV_WABA_ID=
WHATSAPP_DEV_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Fila de atendimento (WAITING): tenta atribuir automaticamente quando agente ficar disponível
WAITING_QUEUE_JOB_ENABLED=true
WAITING_QUEUE_JOB_INTERVAL_MS=30000

# --- Sistema externo de tickets (opcional) ---
# Ao criar usuário no painel, também chama a API do sistema de tickets e grava ticketSystemUserId.
# Menu "Tickets" redireciona para EXTERNAL_TICKET_PORTAL_URL (mesma aba).
# EXTERNAL_TICKET_ENABLED=true
# EXTERNAL_TICKET_API_BASE_URL=https://seu-helpdesk.com
# EXTERNAL_TICKET_API_TOKEN=
# Caminho POST para criar usuário (relativo à base), ex: /api/v1/integrations/users
# EXTERNAL_TICKET_CREATE_PATH=/api/v1/integrations/users
# Enviar senha inicial no JSON (muitas APIs exigem). Desligue se a API não aceitar.
# EXTERNAL_TICKET_SEND_PASSWORD=true
# JSON extra mesclado no corpo do POST (ex.: perfil/função no helpdesk)
# EXTERNAL_TICKET_CREATE_BODY_EXTRA={"role":"agent"}
# Liga/desliga mapeamento dinâmico por usuário (username, role/cargo, setor, setores, active)
# EXTERNAL_TICKET_DYNAMIC_USER_MAP=true
# Fallback de setor quando o usuário local não tiver setor vinculado
# EXTERNAL_TICKET_DEFAULT_SECTOR=Atendimento
# Se true, falha na API de tickets faz o cadastro local retornar erro (rollback manual).
# EXTERNAL_TICKET_STRICT=false
# URL do painel de tickets no navegador (usuário clica em Tickets e cai aqui)
# EXTERNAL_TICKET_PORTAL_URL=https://seu-helpdesk.com
# SSO Exchange (preferencial para login unificado e token curto)
# EXTERNAL_TICKET_SSO_ENABLED=true
# EXTERNAL_TICKET_SSO_EXCHANGE_PATH=/api/v1/sso/exchange
# EXTERNAL_TICKET_SSO_SHARED_SECRET=
# EXTERNAL_TICKET_SSO_EXP_SECONDS=90
# Nome do query param para anexar token no redirect (quando API retorna ticketAccessToken separado)
# EXTERNAL_TICKET_SSO_REDIRECT_QUERY_PARAM=ticketAccessToken
# Anexa ?email=...&ticket_user_id=... se o portal aceitar login por parâmetros (opcional)
# EXTERNAL_TICKET_PORTAL_PASS_EMAIL=false
# Query extra fixa, ex: source=crm
# EXTERNAL_TICKET_PORTAL_QUERY=
# Cabeçalho alternativo à Authorization Bearer, ex: X-Api-Key (o valor continua em EXTERNAL_TICKET_API_TOKEN)
# EXTERNAL_TICKET_API_KEY_HEADER=
