# Copie para .env local. No Coolify, defina as mesmas chaves na UI do serviço.
#
# Coolify (resumo):
# - Tipo: Dockerfile na raiz do repositório
# - Porta do container: 3007 (ou defina PORT e alinhe no painel)
# - Banco: crie um PostgreSQL no Coolify e use a DATABASE_URL gerada
# - Variáveis: todas abaixo + segredos (JWT, WhatsApp, Evolution, etc.)
# - Volume persistente: monte em /app/uploads (mídias / uploads)
# - Build args (opcional): VITE_API_BASE_URL vazio = mesmo domínio da API
# - Domínio público: APP_URL (ou PUBLIC_APP_URL) deve ser URL completa, ex: https://crm.seudominio.com
#   Não defina API_BASE_URL só como "https" — mídia para a Meta falha sem host.

PORT=3007
NODE_ENV=production

# Obrigatório — Postgres (Coolify: use o recurso Database ou URL interna)
DATABASE_URL=postgresql://USER:SENHA@HOST:5432/sistema_atendimento?schema=public

JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legado (não usado com refresh token)
JWT_EXPIRES_IN=7d

# Segurança — recomendado em produção (JWT_SECRET mín. 16 chars, ideal 32+)
METRICS_AUTH_TOKEN=
EVOLUTION_WEBHOOK_SECRET=
MEDIA_SIGNED_URL_SECRET=
PUBLIC_PIPELINE_API_KEY=
PUBLIC_PIPELINE_SIGNATURE_SECRET=
# SECURITY_STRICT_MODE=true bloqueia startup se segredos opcionais estiverem ausentes
# SECURITY_STRICT_MODE=false

# Política de senha
PASSWORD_MIN_LENGTH=12

# Bloqueio de conta após tentativas inválidas
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_PER_MIN=120
# Redis — rate limit distribuído (recomendado com múltiplas réplicas)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_REDIS_PREFIX=rl:
# Antivírus ClamAV (opcional; em produção com CLAMAV_ENABLED=true exige clamd)
# CLAMAV_ENABLED=true
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
# CLAMAV_TIMEOUT_MS=60000
# Incremente no deploy para invalidar JWTs antigos (ex.: 2, 3...)
AUTH_SESSION_EPOCH=1
# Opcional: invalida refresh tokens criados antes desta data (ISO 8601)
# AUTH_REFRESH_NOT_BEFORE=2026-06-09T12:00:00.000Z

# Webhooks/API pública — só use em dev local (bloqueado em produção)
# ALLOW_INSECURE_WEBHOOKS=true
# ALLOW_INSECURE_PUBLIC_API=true
# Logs verbosos de webhook (somente dev; requer flag explícita)
# DEBUG_WEBHOOKS=true

# Criptografia de segredos no banco — obrigatório em produção (64 hex chars ou passphrase 16+)
CHANNEL_SECRETS_ENCRYPTION_KEY=

# Seed local (obrigatório para npm run seed e npm run create:user)
# SEED_ADMIN_PASSWORD=
# SEED_TEST_PASSWORD=

# --- Retenção de mídia (object storage) ---
# MEDIA_RETENTION_ENABLED=true
# MEDIA_RETENTION_DRY_RUN=true
# MEDIA_RETENTION_DAYS=120
# MEDIA_RETENTION_INTERVAL_MS=3600000
# MEDIA_RETENTION_BATCH_SIZE=50

# --- Retenção LGPD (contatos, conversas encerradas, audit logs) ---
# Recomendado em produção: habilitar com dry-run por 1-2 semanas antes de aplicar
# DATA_RETENTION_ENABLED=true
# DATA_RETENTION_DRY_RUN=true
# DATA_RETENTION_CONTACT_DAYS=365
# DATA_RETENTION_CONVERSATION_DAYS=730
# DATA_RETENTION_AUDIT_LOG_DAYS=365
# DATA_RETENTION_INTERVAL_MS=86400000
# DATA_RETENTION_BATCH_SIZE=25

# SSRF — domínios permitidos para fetch de mídia remota (separados por vírgula)
# MEDIA_FETCH_URL_ALLOWLIST=s3.amazonaws.com,minio.seudominio.com

# --- Armazenamento de mídia (MinIO / S3-compatível) ---
# Sem STORAGE_PROVIDER=minio, arquivos ficam só em /app/uploads no volume local.
STORAGE_PROVIDER=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=crm-media
MINIO_REGION=us-east-1
# Prefixo das chaves no bucket (ex: uploads/arquivo.jpg)
MEDIA_OBJECT_PREFIX=uploads
# URL pública do MinIO (opcional; o CRM serve mídia via /api/media/file/ assinado)
MEDIA_PUBLIC_BASE_URL=
# Manter cópia local após upload no object storage (debug/recuperação)
MEDIA_LOCAL_FALLBACK_ENABLED=false
# TTL das URLs assinadas (CRM e presigned MinIO) em segundos
MEDIA_SIGNED_URL_TTL_SECONDS=300
# Rate limit do endpoint público n8n (/api/webhooks/n8n/receive)
N8N_WEBHOOK_RATE_LIMIT_MAX=60
# Token para jobs internos baixarem mídia autenticada (mediaPersistJob)
INTERNAL_MEDIA_TOKEN=

# URL pública do painel (mesma URL que o usuário acessa no navegador)
CORS_ORIGIN=https://app.seudominio.com
APP_URL=https://app.seudominio.com
API_BASE_URL=https://app.seudominio.com
# Opcional: sobrescreve APP_URL só para montar links de mídia (WhatsApp Official)
# PUBLIC_APP_URL=https://app.seudominio.com

# Evolution API (Node) — canais com provider evolution
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Evolution GO — canais com provider evolution_go (Coolify / evoapicloud)
EVOLUTION_GO_API_URL=
EVOLUTION_GO_API_KEY=
# Timeout em ms: create/connect podem levar 30–90s na primeira subida
EVOLUTION_GO_INSTANCE_TIMEOUT_MS=90000
EVOLUTION_GO_TIMEOUT_MS=30000

# Opcional — só se o front for buildado apontando para outra API
# No Dockerfile/Coolify Build Argument: VITE_API_BASE_URL

# WhatsApp Official (se usar)
WHATSAPP_ENV=dev
WHATSAPP_DEV_TOKEN=
WHATSAPP_DEV_PHONE_NUMBER_ID=
WHATSAPP_DEV_WABA_ID=
WHATSAPP_DEV_WEBHOOK_VERIFY_TOKEN=
# App Secret por canal (interface de Canais). WHATSAPP_APP_SECRET no .env é fallback opcional legado.
# WHATSAPP_APP_SECRET=

# Fila de atendimento (WAITING): tenta atribuir automaticamente quando agente ficar disponível
WAITING_QUEUE_JOB_ENABLED=true
WAITING_QUEUE_JOB_INTERVAL_MS=30000
